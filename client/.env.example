# 배포된 백엔드 API 주소 (예: https://your-app.herokuapp.com), 비워두면 로컬(127.0.0.1:5000) 사용
VITE_API_BASE_URL=

# Cloudinary Dashboard > Settings에서 확인하는 Cloud name
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name

# Cloudinary Dashboard > Settings > Upload > Upload presets에서 만든 unsigned preset 이름
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset
